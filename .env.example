# ==========================================
# VARIABLES DE ENTORNO - CONFIGURACIÓN
# ==========================================
# Copy this file to .env.local and fill in your values

# ==========================================
# SERVIDOR (Privadas - NO compartir)
# ==========================================

# Groq API Key - Get free at https://console.groq.com
# Required for: AI routine generation
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# CLIENTE (Públicas - NEXT_PUBLIC_)
# ==========================================

# Google Analytics
# Get from: https://analytics.google.com
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google AdSense
# Get from: https://adsense.google.com
# Format: ca-pub-xxxxxxxxxxxxxxxx
NEXT_PUBLIC_ADSENSE_ID=ca-pub-xxxxxxxxxxxxxxxx

# Site URL
# Development: http://localhost:3000
# Production: https://tudominio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ==========================================
# NOTAS PARA VERCEL
# ==========================================
# 1. Add these variables to Vercel Dashboard:
#    Project Settings > Environment Variables
# 2. Use NEXT_PUBLIC_ prefix for public variables
# 3. Do NOT include .env.local in git (see .gitignore)
# 4. Set different values for preview/production if needed
